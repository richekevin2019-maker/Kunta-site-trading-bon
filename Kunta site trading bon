<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kunta Spirit Trading | Formation Trading Premium</title>
<meta name="description" content="Kunta Spirit Trading — Formation Price Action avancé. Forex, Indices Synthétiques, Crypto, Matières Premières. Swing, Intraday, Scalping. +200 traders formés depuis 2020.">
<meta property="og:title" content="Kunta Spirit Trading | Formation Trading Premium">
<meta property="og:description" content="Maîtrisez le Price Action avancé. Stratégies de mentors millionnaires. Bénin & Afrique.">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Oswald:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --red:#e00;
  --red-bright:#ff2020;
  --red-dark:#a80000;
  --bg:#08080a;
  --bg-card:#100a0a;
  --bg-card2:#160c0c;
  --text:#f0eaea;
  --muted:#998888;
  --border:rgba(220,0,0,.18);
  --glow:rgba(220,0,0,.32);
  --gold:#f0c040;
  --gold-dim:rgba(240,192,64,.15);
  --green:#00e676;
  --wa:#25d366;
  --wa-dark:#128c4a;
}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;cursor:none;}
.cursor{position:fixed;width:10px;height:10px;background:var(--red-bright);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .2s,height .2s;mix-blend-mode:screen;}
.cursor-follower{position:fixed;width:38px;height:38px;border:1px solid rgba(220,0,0,.4);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:all .15s ease-out;}
body::before{content:'';position:fixed;inset:0;opacity:.35;pointer-events:none;z-index:1;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.03'/%3E%3C/svg%3E");}

/* TOP BANNER */
.review-track{display:inline-flex;gap:50px;animation:rticker 35s linear infinite;white-space:nowrap;}
.rev-item{display:inline-flex;align-items:center;gap:8px;font-size:.76rem;padding:8px 0;border-right:1px solid rgba(240,192,64,.1);padding-right:50px;}
@keyframes rticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* NAV */
nav{position:fixed;top:34px;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:18px 5%;background:rgba(8,8,10,.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);transition:all .3s;}
.nav-logo{font-family:'Anton',sans-serif;font-size:1.3rem;color:var(--red-bright);letter-spacing:3px;text-transform:uppercase;line-height:1.1;}
.nav-logo span{display:block;font-family:'DM Sans',sans-serif;font-size:.55rem;color:var(--muted);letter-spacing:4px;font-weight:400;text-transform:uppercase;}
.nav-links{display:flex;gap:30px;list-style:none;}
.nav-links a{color:var(--muted);text-decoration:none;font-size:.8rem;letter-spacing:1px;text-transform:uppercase;transition:color .3s;}
.nav-links a:hover{color:var(--red-bright);}
.nav-cta{background:var(--wa);color:#fff;padding:10px 22px;border-radius:4px;text-decoration:none;font-weight:700;font-size:.84rem;letter-spacing:1px;transition:all .3s;box-shadow:0 0 20px rgba(37,211,102,.3);}
.nav-cta:hover{background:#20c95c;box-shadow:0 0 35px rgba(37,211,102,.5);}

/* HERO */
#hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:140px 5% 80px;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% 0%,rgba(220,0,0,.1) 0%,transparent 70%),radial-gradient(ellipse 40% 40% at 10% 90%,rgba(220,0,0,.05) 0%,transparent 60%),var(--bg);}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(220,0,0,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(220,0,0,.04) 1px,transparent 1px);background-size:55px 55px;mask-image:radial-gradient(ellipse at center,black 25%,transparent 72%);}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(220,0,0,.1);border:1px solid var(--border);padding:8px 20px;border-radius:50px;margin-bottom:28px;font-size:.76rem;letter-spacing:2px;text-transform:uppercase;color:var(--red-bright);animation:fadeDown .8s ease both;}
.dot-blink{width:6px;height:6px;background:var(--red-bright);border-radius:50%;animation:blink 1.5s infinite;}

/* HERO TITLE — ANTON */
h1.hero-title{font-family:'Anton',sans-serif;font-size:clamp(3.5rem,9vw,8rem);line-height:.95;margin-bottom:24px;animation:fadeUp .8s .2s ease both;letter-spacing:3px;text-transform:uppercase;}
.line1{display:block;color:var(--text);}
.line2{display:block;color:var(--red-bright);text-shadow:0 0 80px rgba(220,0,0,.6),0 0 160px rgba(220,0,0,.3);}

.hero-sub{max-width:650px;font-size:1.05rem;color:var(--muted);line-height:1.85;margin-bottom:38px;animation:fadeUp .8s .4s ease both;}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;animation:fadeUp .8s .6s ease both;}

/* BUTTONS */
.btn-primary{display:inline-flex;align-items:center;gap:10px;background:var(--red);color:#fff;padding:16px 32px;border-radius:6px;text-decoration:none;font-weight:700;font-size:1rem;box-shadow:0 0 40px var(--glow);transition:all .3s;position:relative;overflow:hidden;}
.btn-primary::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);transform:translateX(-100%);transition:transform .5s;}
.btn-primary:hover::before{transform:translateX(100%);}
.btn-primary:hover{background:var(--red-bright);box-shadow:0 0 60px rgba(255,32,32,.6);transform:translateY(-2px);}
.btn-wa{display:inline-flex;align-items:center;gap:10px;background:var(--wa);color:#fff;padding:16px 32px;border-radius:6px;text-decoration:none;font-weight:700;font-size:1rem;box-shadow:0 0 30px rgba(37,211,102,.35);transition:all .3s;position:relative;overflow:hidden;}
.btn-wa::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);transform:translateX(-100%);transition:transform .5s;}
.btn-wa:hover::before{transform:translateX(100%);}
.btn-wa:hover{background:#20c95c;box-shadow:0 0 55px rgba(37,211,102,.6);transform:translateY(-2px);}
.btn-secondary{display:inline-flex;align-items:center;gap:10px;border:1px solid var(--border);color:var(--text);padding:16px 32px;border-radius:6px;text-decoration:none;font-weight:500;font-size:1rem;transition:all .3s;}
.btn-secondary:hover{border-color:var(--red-bright);color:var(--red-bright);}

.hero-trust{display:flex;gap:40px;flex-wrap:wrap;justify-content:center;margin-top:55px;animation:fadeUp .8s .8s ease both;}
.trust-num{font-family:'Oswald',sans-serif;font-size:2rem;color:var(--red-bright);font-weight:700;}
.trust-label{font-size:.74rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;}
.trust-div{width:1px;background:var(--border);height:38px;align-self:center;}

/* TICKER MARKETS */
.ticker-wrap{background:rgba(220,0,0,.06);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:11px 0;overflow:hidden;white-space:nowrap;}
.ticker-track{display:inline-flex;gap:50px;animation:ticker 22s linear infinite;white-space:nowrap;}
.ticker-item{display:inline-flex;align-items:center;gap:8px;font-size:.8rem;letter-spacing:1px;text-transform:uppercase;color:var(--muted);}
.tdot{width:5px;height:5px;background:var(--red-bright);border-radius:50%;flex-shrink:0;}

/* SEP */
.sep{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);}

/* SECTION TITLES — OSWALD */
.stag{display:inline-block;font-size:.72rem;letter-spacing:3px;text-transform:uppercase;color:var(--red-bright);margin-bottom:14px;padding:5px 15px;border:1px solid var(--border);border-radius:50px;background:rgba(220,0,0,.06);}
.stitle{font-family:'Oswald',sans-serif;font-size:clamp(2.2rem,5vw,4rem);font-weight:700;line-height:1.05;margin-bottom:14px;letter-spacing:1px;text-transform:uppercase;}
.stitle span{color:var(--red-bright);}
.ssub{color:var(--muted);font-size:.94rem;line-height:1.85;max-width:580px;}
.shd{margin-bottom:55px;}
.sw{padding:100px 5%;}
.si{max-width:1100px;margin:0 auto;}

/* PROBLÈME */
.prob-wrap{display:grid;grid-template-columns:1fr 280px;gap:30px;align-items:center;background:rgba(220,0,0,.04);border:1px solid rgba(220,0,0,.15);border-radius:16px;padding:35px;margin-top:45px;}
.prob-wrap img{width:100%;border-radius:10px;display:block;}
.prob-item{display:flex;align-items:flex-start;gap:12px;margin-bottom:18px;}
.prob-item:last-child{margin-bottom:0;}
.px{color:#ff5555;font-size:1.3rem;flex-shrink:0;}

/* À PROPOS */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:65px;align-items:start;}
.aphoto-main{border-radius:14px;overflow:hidden;border:2px solid var(--border);}
.aphoto-main img{width:100%;display:block;object-fit:cover;}
.aphoto-sec{border-radius:12px;overflow:hidden;border:1px solid var(--border);margin-top:25px;}
.aphoto-sec img{width:100%;display:block;object-fit:cover;}
.abadge{background:var(--bg-card2);border:1px solid var(--border);border-radius:10px;padding:13px 16px;text-align:center;margin-top:12px;}
.abadge-n{font-family:'Oswald',sans-serif;font-size:1.8rem;color:var(--red-bright);display:block;letter-spacing:2px;}
.abadge-l{font-size:.72rem;color:var(--muted);letter-spacing:1px;}
.astat-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px;}
.astat{background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:16px;text-align:center;}
.astat-n{font-family:'Oswald',sans-serif;font-size:1.4rem;color:var(--red-bright);letter-spacing:1px;}
.astat-l{font-size:.7rem;color:var(--muted);margin-top:3px;}
.at p{font-size:.94rem;line-height:1.9;color:var(--muted);margin-bottom:18px;}
.hl{display:flex;align-items:flex-start;gap:12px;background:var(--bg-card);border:1px solid var(--border);border-left:3px solid var(--red);border-radius:10px;padding:18px;margin:22px 0;font-size:.92rem;}
.hl-ic{color:var(--red-bright);font-size:1.1rem;flex-shrink:0;padding-top:2px;}

/* MARCHÉS */
.marches-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:14px;margin-top:45px;}
.mc{background:var(--bg);border:1px solid var(--border);border-radius:12px;padding:24px 16px;text-align:center;transition:all .3s;}
.mc:hover{border-color:var(--red-bright);transform:translateY(-4px);box-shadow:0 10px 40px rgba(220,0,0,.12);}
.mc-icon{font-size:2.2rem;margin-bottom:10px;}
.mc h4{font-family:'Oswald',sans-serif;font-size:1rem;font-weight:600;margin-bottom:4px;letter-spacing:.5px;}
.mc p{font-size:.76rem;color:var(--muted);}

/* MÉTHODE */
.method-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(265px,1fr));gap:20px;margin-top:45px;}
.mcard{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:30px;position:relative;overflow:hidden;transition:all .3s;}
.mcard:hover{border-color:var(--red-bright);transform:translateY(-4px);box-shadow:0 20px 60px rgba(220,0,0,.1);}
.mnum{font-family:'Anton',sans-serif;font-size:3.5rem;color:rgba(220,0,0,.07);position:absolute;top:10px;right:18px;letter-spacing:2px;}
.micon{font-size:1.9rem;margin-bottom:15px;}
.mcard h3{font-family:'Oswald',sans-serif;font-size:1.1rem;font-weight:700;margin-bottom:10px;letter-spacing:.5px;text-transform:uppercase;}
.mcard p{font-size:.87rem;color:var(--muted);line-height:1.7;}
.mcard ul{list-style:none;margin-top:13px;}
.mcard ul li{font-size:.83rem;color:var(--muted);padding:5px 0;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;}
.mcard ul li::before{content:'▸';color:var(--red-bright);font-size:.68rem;}

/* STRAT BOX */
.strat-box{background:linear-gradient(135deg,rgba(220,0,0,.08),rgba(220,0,0,.02));border:1px solid var(--border);border-left:3px solid var(--red-bright);border-radius:16px;padding:45px;margin-top:50px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;}
.strat-box h3{font-family:'Oswald',sans-serif;font-size:2rem;letter-spacing:1px;margin-bottom:15px;text-transform:uppercase;}
.strat-box h3 span{color:var(--red-bright);}
.strat-box p{font-size:.93rem;color:var(--muted);line-height:1.85;}
.strat-list{list-style:none;display:flex;flex-direction:column;gap:12px;}
.strat-list li{display:flex;align-items:flex-start;gap:12px;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:14px;font-size:.88rem;}
.sb{width:8px;height:8px;background:var(--red-bright);border-radius:50%;flex-shrink:0;margin-top:5px;box-shadow:0 0 8px var(--red-bright);}

/* PROGRAMME */
.prog-tabs{display:flex;border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:32px;}
.prog-tab{flex:1;padding:14px;text-align:center;background:var(--bg-card);color:var(--muted);cursor:pointer;border:none;font-family:'DM Sans',sans-serif;font-size:.87rem;transition:all .3s;border-right:1px solid var(--border);}
.prog-tab:last-child{border-right:none;}
.prog-tab.active{background:var(--red);color:#fff;font-weight:700;}
.prog-content{display:none;}
.prog-content.active{display:block;}
.prog-modules{display:flex;flex-direction:column;gap:11px;}
.prog-mod{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color .3s;}
.prog-mod.open{border-color:rgba(220,0,0,.4);}
.prog-mod-head{display:flex;align-items:center;gap:13px;padding:17px 20px;cursor:pointer;}
.prog-week{background:rgba(220,0,0,.12);color:var(--red-bright);padding:3px 11px;border-radius:20px;font-size:.7rem;font-weight:600;letter-spacing:1px;white-space:nowrap;}
.prog-mod-title{font-family:'Rajdhani',sans-serif;font-weight:600;font-size:1rem;flex:1;letter-spacing:.3px;}
.prog-toggle{color:var(--red-bright);font-size:1.2rem;transition:transform .3s;font-weight:300;flex-shrink:0;}
.prog-mod.open .prog-toggle{transform:rotate(45deg);}
.prog-mod-body{padding:0 20px;max-height:0;overflow:hidden;transition:all .4s;}
.prog-mod.open .prog-mod-body{max-height:500px;padding:0 20px 18px;}
.prog-mod-body ul{list-style:none;}
.prog-mod-body ul li{padding:7px 0;border-bottom:1px solid var(--border);font-size:.87rem;color:var(--muted);display:flex;align-items:center;gap:9px;}
.prog-mod-body ul li::before{content:'→';color:var(--red-bright);}

/* URGENCE */
.urgence-box{background:linear-gradient(135deg,rgba(220,0,0,.08),transparent);border:1px solid var(--border);border-radius:20px;padding:55px;text-align:center;position:relative;overflow:hidden;max-width:1100px;margin:0 auto;}
.urgence-box::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--red),transparent);}
.cd-grid{display:flex;gap:16px;justify-content:center;margin:32px 0;flex-wrap:wrap;}
.cd-item{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:16px 26px;min-width:80px;position:relative;overflow:hidden;}
.cd-item::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--red-bright);}
.cd-num{font-family:'Anton',sans-serif;font-size:3rem;color:var(--red-bright);display:block;letter-spacing:3px;}
.cd-label{font-size:.66rem;color:var(--muted);text-transform:uppercase;letter-spacing:2px;}
.seats-bar{max-width:380px;margin:0 auto 16px;background:var(--bg-card);border:1px solid var(--border);border-radius:50px;height:10px;overflow:hidden;}
.seats-fill{height:100%;width:72%;background:linear-gradient(90deg,var(--red-dark),var(--red-bright));border-radius:50px;animation:barFill 2s ease both;}

/* ===== PRIX — DESIGN PREMIUM ===== */
.pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:24px;margin-top:45px;}
.pcard{background:var(--bg);border:1px solid var(--border);border-radius:20px;padding:0;position:relative;transition:all .3s;overflow:hidden;}
.pcard.featured{border-color:var(--red-bright);box-shadow:0 0 60px rgba(220,0,0,.15);}
.pcard-top{padding:32px 32px 24px;}
.pcard-top-featured{background:linear-gradient(135deg,rgba(220,0,0,.12),rgba(220,0,0,.04));}
.pbadge{position:absolute;top:0;right:24px;background:var(--red);color:#fff;padding:6px 18px;border-radius:0 0 10px 10px;font-size:.72rem;font-weight:700;letter-spacing:1px;}
.pcard h3{font-family:'Anton',sans-serif;font-size:1.6rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;}
.pmode{display:inline-flex;align-items:center;gap:6px;font-size:.74rem;color:var(--muted);background:rgba(220,0,0,.08);border:1px solid var(--border);padding:3px 10px;border-radius:20px;margin-bottom:12px;}
.pdesc{font-size:.84rem;color:var(--muted);margin-bottom:20px;line-height:1.6;}
.price-box{background:rgba(0,0,0,.3);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:0;text-align:center;}
.pamount{font-family:'Anton',sans-serif;font-size:3rem;color:var(--red-bright);letter-spacing:3px;line-height:1;display:block;}
.pcurr{font-size:1rem;color:var(--muted);display:block;margin-top:4px;font-family:'DM Sans',sans-serif;}
.pcard-body{padding:24px 32px 32px;}
.pfeat{list-style:none;margin-bottom:26px;}
.pfeat li{padding:9px 0;border-bottom:1px solid var(--border);font-size:.88rem;display:flex;align-items:flex-start;gap:9px;line-height:1.5;}
.ck{color:var(--green);flex-shrink:0;}
.no{color:#444;flex-shrink:0;}
.pcta{display:block;text-align:center;background:var(--wa);color:#fff;padding:15px;border-radius:10px;text-decoration:none;font-weight:700;font-size:.95rem;transition:all .3s;letter-spacing:.5px;box-shadow:0 0 20px rgba(37,211,102,.2);}
.pcta:hover{background:#20c95c;transform:translateY(-2px);box-shadow:0 0 40px rgba(37,211,102,.4);}
.pcta-outline{display:block;text-align:center;background:transparent;border:1px solid rgba(37,211,102,.3);color:var(--wa);padding:15px;border-radius:10px;text-decoration:none;font-weight:700;font-size:.95rem;transition:all .3s;}
.pcta-outline:hover{background:rgba(37,211,102,.1);border-color:var(--wa);}
.flyer-wrap{margin-top:50px;text-align:center;}
.flyer-wrap img{max-width:470px;width:100%;border-radius:16px;border:1px solid var(--border);box-shadow:0 20px 80px rgba(220,0,0,.15);}
.flyer-cap{font-size:.82rem;color:var(--muted);margin-top:12px;}

/* PROOF SCREENS */
.proof-screens{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:40px;}
.pscreen-card{background:#0c0c10;border:1px solid rgba(255,255,255,.08);border-radius:14px;overflow:hidden;font-family:'Rajdhani',sans-serif;}
.pscreen-header{background:#161620;padding:12px 16px;display:flex;align-items:center;gap:8px;border-bottom:1px solid rgba(255,255,255,.06);}
.pscreen-dot{width:10px;height:10px;border-radius:50%;}
.pscreen-dot.red{background:#ff5f57;}
.pscreen-dot.amber{background:#febc2e;}
.pscreen-dot.green{background:#28c840;}
.pscreen-platform{font-size:.75rem;color:#888;margin-left:8px;letter-spacing:1px;font-family:'DM Sans',sans-serif;}
.pscreen-body{padding:18px;}
.pscreen-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.05);}
.psl{font-size:.85rem;color:#888;}
.psv{font-size:1.05rem;font-weight:700;letter-spacing:1px;}
.psv.green{color:#00e676;}
.psv.red{color:#ff5252;}
.psv.white{color:#ddd;}
.psv.gold{color:#f0c040;}
.pscreen-divider{height:1px;background:rgba(240,192,64,.15);margin:8px 0;}
.pscreen-footer{padding:10px 18px;background:#0e0e18;font-size:.75rem;color:#666;font-family:'DM Sans',sans-serif;border-top:1px solid rgba(255,255,255,.05);}
.pscreen-trade{display:grid;grid-template-columns:1fr auto auto;gap:10px;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);}
.pscreen-trade.win{border-left:2px solid #00e676;padding-left:10px;}
.pscreen-trade.loss{border-left:2px solid #ff5252;padding-left:10px;}
.ptr-pair{font-size:.85rem;color:#ccc;font-weight:700;}
.ptr-type{font-size:.72rem;background:rgba(255,255,255,.05);padding:2px 8px;border-radius:4px;color:#888;}
.ptr-pnl{font-size:.9rem;font-weight:700;text-align:right;}
